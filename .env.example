# --- Core ---
NODE_ENV=development
PORT=4000

# Comma-separated list of allowed origins, or "*" for any (dev only).
CORS_ORIGIN=http://localhost:3000

# Public URL of the frontend — used to build password-reset and email-
# verification links in transactional emails. Defaults to CORS_ORIGIN.
FRONTEND_URL=http://localhost:3000

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/support-saas

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- OpenAI (optional in dev, required for AI reply / summary / RAG) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Intercom (optional — needed for outbound replies and webhook ingest) ---
INTERCOM_API_KEY=
INTERCOM_ADMIN_ID=
INTERCOM_CLIENT_SECRET=

# --- Resend (transactional email) -------------------------------------------
# Without these set, forgot-password and email-verification messages are
# skipped silently. In Railway logs this shows as
# `transactional_email_skipped` with reason `no_api_key`.
#
# RESEND_FROM_EMAIL MUST be on a domain you have verified in the Resend
# dashboard (https://resend.com/domains). Resend rejects sends from
# unverified domains — the default placeholder below will fail.
#
# After setting, run `npm run test-email -- you@example.com` to confirm.
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@yourdomain.com
